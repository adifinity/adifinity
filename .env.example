# Sanity project connection (safe to be public — identifies the project, not a secret)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production

# Sanity API token with "Viewer" role, used server-side to read draft content
# for Draft Mode and the Presentation tool. Create one at manage.sanity.io
# (Project -> API -> Tokens) and never commit the real value.
SANITY_API_READ_TOKEN=your-viewer-token
